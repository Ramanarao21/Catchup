<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Catchup" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      .navbar {
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
      }
      .navbar-brand {
        font-weight: 700;
        font-size: 1.5rem;
        letter-spacing: -0.5px;
      }
      .nav-link {
        font-weight: 500;
        padding: 0.5rem 1rem !important;
        transition: all 0.2s ease;
      }
      .nav-link:hover {
        background-color: rgba(255,255,255,0.1);
        border-radius: 6px;
      }
      .alert {
        border: none;
        border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.04);
      }
      .btn {
        padding: 0.5rem 1.25rem;
        font-weight: 500;
        border-radius: 6px;
      }
      .main-content {
        min-height: calc(100vh - 180px);
      }
      footer {
        border-top: 1px solid rgba(0,0,0,.05);
      }
    </style>
  </head>

  <body class="min-vh-100 d-flex flex-column bg-light">
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
      <div class="container py-2">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
          <i class="fas fa-comments me-2"></i> Catchup
        <% end %>
        
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <% if user_signed_in? %>
              <li class="nav-item mx-1">
                <%= link_to root_path, class: "nav-link d-flex align-items-center" do %>
                  <i class="fas fa-home me-2"></i> Home
                <% end %>
              </li>
              <li class="nav-item mx-1">
                <%= link_to friendships_path, class: "nav-link d-flex align-items-center" do %>
                  <i class="fas fa-users me-2"></i> Friends
                <% end %>
              </li>
              <li class="nav-item mx-1">
                <%= link_to edit_user_registration_path, class: "nav-link d-flex align-items-center" do %>
                  <i class="fas fa-user-cog me-2"></i> Account
                <% end %>
              </li>
              <li class="nav-item mx-1">
                <%= link_to destroy_user_session_path, 
                    method: :delete, 
                    class: "nav-link d-flex align-items-center",
                    data: { turbo_method: :delete } do %>
                  <i class="fas fa-sign-out-alt me-2"></i> Logout
                <% end %>
              </li>
            <% else %>
              <li class="nav-item mx-1">
                <%= link_to new_user_session_path, class: "nav-link d-flex align-items-center" do %>
                  <i class="fas fa-sign-in-alt me-2"></i> Login
                <% end %>
              </li>
              <li class="nav-item mx-1">
                <%= link_to new_user_registration_path, class: "btn btn-light ms-2" do %>
                  <i class="fas fa-user-plus me-2"></i> Sign Up
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow-1 py-4 main-content">
      <div class="container">
        <!-- Flash Messages -->
        <% flash.each do |name, msg| %>
          <% if msg.is_a?(String) %>
            <div class="alert alert-<%= name == :notice ? "success" : "danger" %> alert-dismissible fade show mb-4">
              <div class="d-flex align-items-center">
                <i class="fas fa-<%= name == :notice ? "check-circle" : "exclamation-circle" %> me-2"></i>
                <%= msg %>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>
        <% end %>

        <%= yield %>
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white py-4 mt-auto">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-md-6 text-center text-md-start">
            <p class="mb-0 text-muted">
              <strong>Catchup</strong> &copy; <%= Time.current.year %>. All rights reserved.
            </p>
          </div>
          <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
            <a href="#" class="text-muted text-decoration-none me-3">
              <i class="fab fa-twitter"></i>
            </a>
            <a href="#" class="text-muted text-decoration-none me-3">
              <i class="fab fa-facebook"></i>
            </a>
            <a href="#" class="text-muted text-decoration-none">
              <i class="fab fa-instagram"></i>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Bootstrap JavaScript Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>