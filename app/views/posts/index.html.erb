<h2>All Posts</h2>

<% @posts.each do |post| %>
  <div class="card mb-3">
    <div class="card-body">
      <h5 class="card-title"><%= post.user.name %></h5>
      <p class="card-text"><%= post.content %></p>
      <small class="text-muted">Posted on <%= post.created_at.strftime("%b %d, %Y") %></small>
    </div>
  </div>
<% end %>
