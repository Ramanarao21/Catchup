<div class="container mt-4">
  <header class="d-flex justify-content-between align-items-center">
    <h2>Catchup</h2>
    <nav>
      <%= link_to "Home", root_path, class: "btn btn-primary" %>
      <%= link_to "Friends", friendships_path, class: "btn btn-outline-primary ms-2" %>
    </nav>
  </header>

  <div class="text-end my-3">
    <%= link_to "+ Share a thought", new_post_path, class: "btn btn-outline-primary" %>
  </div>

  <div class="card shadow p-3">
    <h3>Latest Thoughts</h3>
    
    <% @posts.each do |post| %>
      <div class="d-flex align-items-start border-bottom pb-3 mb-3">
        <%= image_tag 'avatar.png', class: "rounded-circle", width: 50, height: 50 %>
        
        <div class="flex-grow-1">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="bg-primary text-white p-2 rounded"><%= post.user.name %></h5>
            <small class="text-muted"><%= time_ago_in_words(post.created_at) %> ago</small>
          </div>

          <p><%= post.content %></p>

          <div class="d-flex align-items-center">
            <span>👍 <%= post.likes_count %> likes</span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
